# Nexus Configuration
# Copy this file to ~/.flossware/nexus/nexus.properties and update with your credentials

# Required: Nexus server URL (without trailing slash)
nexus.url=https://your-nexus-server.com

# Required: Nexus username
nexus.user=your-username

# Required: Nexus password or token
nexus.password=your-password-or-token

# Optional: Default repository name for UI
#nexus.default.repository=maven-releases

# Optional: Default regex filter for UI
#nexus.default.regex=.*SNAPSHOT.*

# Optional: Default dry-run mode for UI (true/false)
#nexus.default.dryrun=true
