# Nexus Configuration
# Copy this file to ~/.flossware/nexus/nexus.properties and update with your credentials

# Required: Nexus server URL (without trailing slash)
nexus.url=https://your-nexus-server.com

# Required: Nexus username
nexus.user=your-username

# Required: Nexus password or token
nexus.password=your-password-or-token

# Optional: Default repository name for UI
#nexus.default.repository=maven-releases

# Optional: Default regex filter for UI
#nexus.default.regex=.*SNAPSHOT.*

# Optional: Default dry-run mode for UI (true/false)
#nexus.default.dryrun=true

# Optional: Comma-separated list of repositories (for dropdowns/batch operations)
# Whitespace around commas is automatically trimmed
#nexus.repositories=maven-releases,maven-snapshots,npm-public,docker-hosted

# Optional: HTTP connection timeout in seconds (default: 30)
# Can also be set via NEXUS_HTTP_TIMEOUT environment variable
#nexus.http.timeout.seconds=30

# Optional: Maximum number of retry attempts for failed HTTP requests (default: 3, range: 0-10)
# Can also be set via NEXUS_MAX_RETRIES environment variable
#nexus.http.max.retries=3

# Optional: Initial retry delay in milliseconds for exponential backoff (default: 1000, range: 0-60000)
# Delay doubles with each retry: 1s, 2s, 4s, 8s, etc.
# Can also be set via NEXUS_RETRY_DELAY_MS environment variable
#nexus.http.retry.delay.ms=1000

# Optional: Log level (default: INFO)
# Valid values: TRACE, DEBUG, INFO, WARN, ERROR, OFF
# Can also be set via NEXUS_LOG_LEVEL environment variable
#nexus.log.level=INFO
