# Production Profile Configuration
# Copy this file to ~/.flossware/nexus/nexus-prod.properties and update with your production credentials
# Use via: NEXUS_PROFILE=prod or --profile prod

# Required: Nexus server URL (without trailing slash)
nexus.url=https://prod-nexus.example.com

# Required: Nexus username
nexus.user=prod-username

# Required: Nexus password or token
nexus.password=prod-password-or-token

# Optional: Default repository name for UI
nexus.default.repository=maven-releases

# Optional: Default regex filter for UI
#nexus.default.regex=

# Optional: Default dry-run mode for UI (true/false)
# IMPORTANT: Consider keeping dry-run enabled for production to prevent accidental deletions
nexus.default.dryrun=true

# Optional: Comma-separated list of repositories (for dropdowns/batch operations)
nexus.repositories=maven-releases,npm-public,docker-releases

# Optional: HTTP connection timeout in seconds (default: 30)
nexus.http.timeout.seconds=45
